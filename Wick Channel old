f_refresh_pivot_flags(bool[] hiFlags, bool[] loFlags, int safeHist, int pivotLen) =>
    int needed = safeHist + 1
    while array.size(hiFlags) < needed
        array.push(hiFlags, false)
        array.push(loFlags, false)
    for off = 0 to safeHist
        bool isHigh = false
        bool isLow = false
        if off >= pivotLen and off + pivotLen <= safeHist
            float ph = high[off]
            float pl = low[off]
            isHigh := true
            isLow := true
            for j = 1 to pivotLen
                isHigh := isHigh and ph > high[off - j] and ph >= high[off + j]
                isLow := isLow and pl < low[off - j] and pl <= low[off + j]
        array.set(hiFlags, off, isHigh)
        array.set(loFlags, off, isLow)

f_is_pivot_high_off(int off, int safeHist) =>
    off >= 0 and off <= safeHist and off < array.size(pivotHighFlags) ? array.get(pivotHighFlags, off) : false

f_is_pivot_low_off(int off, int safeHist) =>
    off >= 0 and off <= safeHist and off < array.size(pivotLowFlags) ? array.get(pivotLowFlags, off) : false

f_count_touch_hits(int p1x, int xEnd, float slope, float intercept, float widthUp, float widthDn, float midTol, float outerTol, int safeHist, bool useMid, bool useRails) =>
    int hits = 0
    for xb = p1x to xEnd
        int off = bar_index - xb
        float midY = intercept + slope * (xb - p1x)
        bool isPivotHigh = f_is_pivot_high_off(off, safeHist)
        bool isPivotLow = f_is_pivot_low_off(off, safeHist)
        bool midHit = useMid and ((isPivotHigh and off >= 0 and off <= safeHist and math.abs(high[off] - midY) <= midTol) or (isPivotLow and off >= 0 and off <= safeHist and math.abs(low[off] - midY) <= midTol))
        bool railHit = useRails and ((isPivotHigh and off >= 0 and off <= safeHist and math.abs(high[off] - (midY + widthUp)) <= outerTol) or (isPivotLow and off >= 0 and off <= safeHist and math.abs(low[off] - (midY - widthDn)) <= outerTol))
        if midHit or railHit
            hits += 1
    hits

