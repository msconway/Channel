            p1Off := array.get(sessionOffs, array.size(sessionOffs) - 1)

    p1x := not na(p1x) ? math.min(p1x, bar_index) : na
    if not na(p1x) and not na(p1Off) and p1x < bar_index and p1x >= 0 and p1Off >= 0
        int barsSinceP1 = bar_index - p1x
        if barsSinceP1 < 0
