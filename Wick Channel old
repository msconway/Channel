f_draw_channel(bool shouldDraw, int p1x, int xEnd, float slope, float intercept, float width, float outerUp, float outerDn, float railExtreme, float score, int len, int totalBars, float insideCnt, float outsideCnt, float insidePct, float recalcInsideCnt, float recalcOutsideCnt, float recalcInsidePct, int midTouches, int railHits, int predHits, string kind, string debugPrefix, color midColor, color railColor, bool extendRight, bool showParallels, bool showExpandedZone, bool showDebug, float[] highOffsets, int[] highCounts, float[] lowOffsets, int[] lowCounts) =>
    if shouldDraw and not na(slope) and not na(width)
        float midL = intercept
        float midR = intercept + slope * (xEnd - p1x)
        float topL = midL + width
        float topR = midR + width
        float botL = midL - width
        float botR = midR - width
        float wideTopL = midL + outerUp
        float wideTopR = midR + outerUp
        float wideBotL = midL - outerDn
        float wideBotR = midR - outerDn
        drawExt = extendRight ? extend.right : extend.none

        line midLine = line.new(p1x, midL, xEnd, midR, xloc=xloc.bar_index, extend=drawExt, color=color.new(midColor, 0), width=1, style=line.style_dashed)
        line topLine = line.new(p1x, topL, xEnd, topR, xloc=xloc.bar_index, extend=drawExt, color=color.new(railColor, 0), width=2)
        line botLine = line.new(p1x, botL, xEnd, botR, xloc=xloc.bar_index, extend=drawExt, color=color.new(railColor, 0), width=2)
        array.push(drawnLines, midLine)
        array.push(drawnLines, topLine)
        array.push(drawnLines, botLine)

        if showParallels
            if array.size(highOffsets) > 0
                for i = 0 to array.size(highOffsets) - 1
                    float offP = array.get(highOffsets, i)
                    int cntP = i < array.size(highCounts) ? array.get(highCounts, i) : 0
                    color cP = math.abs(offP - width) <= syminfo.mintick * 0.5 ? color.new(railColor, 0) : color.new(railColor, 75)
                    int wP = math.abs(offP - width) <= syminfo.mintick * 0.5 ? 2 : 1
                    line lp = line.new(p1x, midL + offP, xEnd, midR + offP, xloc=xloc.bar_index, extend=drawExt, color=cP, width=wP, style=cntP >= 2 ? line.style_solid : line.style_dotted)
                    array.push(drawnLines, lp)
            if array.size(lowOffsets) > 0
                for i = 0 to array.size(lowOffsets) - 1
                    float offP = array.get(lowOffsets, i)
                    int cntP = i < array.size(lowCounts) ? array.get(lowCounts, i) : 0
                    color cP = math.abs(offP - width) <= syminfo.mintick * 0.5 ? color.new(railColor, 0) : color.new(railColor, 75)
                    int wP = math.abs(offP - width) <= syminfo.mintick * 0.5 ? 2 : 1
                    line lp = line.new(p1x, midL - offP, xEnd, midR - offP, xloc=xloc.bar_index, extend=drawExt, color=cP, width=wP, style=cntP >= 2 ? line.style_solid : line.style_dotted)
                    array.push(drawnLines, lp)

        if showExpandedZone
            wideTopL := midL + railExtreme
            wideTopR := midR + railExtreme
            wideBotL := midL - railExtreme
            wideBotR := midR - railExtreme
            line wideTopLine = line.new(p1x, wideTopL, xEnd, wideTopR, xloc=xloc.bar_index, extend=drawExt, color=color.new(railColor, 75), width=1)
            line wideBotLine = line.new(p1x, wideBotL, xEnd, wideBotR, xloc=xloc.bar_index, extend=drawExt, color=color.new(railColor, 75), width=1)
