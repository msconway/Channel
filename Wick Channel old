f_exactTouch(off, y, tol) =>
    int safeHist = math.min(bar_index, 5000)
    off >= 0 and off <= safeHist ? (math.abs(low[off] - y) <= tol or math.abs(high[off] - y) <= tol) : false
f_round_to_step(v, step) => step > 0 ? math.round(v / step) * step : v

f_get_hm_from_session(sess) =>
    string hh = str.substring(sess, 0, 2)
    string mm = str.substring(sess, 2, 4)
    [int(str.tonumber(hh)), int(str.tonumber(mm))]

f_label_y_at_x(topY, botY, expUp, expDn, isUpTrend) =>
    float outerTop = math.max(topY, topY + math.max(expUp - (topY - (topY + botY) * 0.5), 0))
    float outerBot = math.min(botY, botY - math.max(expDn - (((topY + botY) * 0.5) - botY), 0))
    float pad = math.max(outerTop - outerBot, syminfo.mintick * 20) * 0.45
    isUpTrend ? outerBot - pad : outerTop + pad

f_current_day_start() =>
    timestamp(year(timenow, sessionTimezone), month(timenow, sessionTimezone), dayofmonth(timenow, sessionTimezone), 0, 0)

