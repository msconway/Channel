                            if pivotMidTouch
                                midTouches += 1
                            float upOff = isPivotHigh and off >= 0 and off <= safeHist ? high[off] - midY : na
                            float dnOff = isPivotLow and off >= 0 and off <= safeHist ? midY - low[off] : na
                            if not na(upOff) and upOff > 0
                                float keyU = f_round_to_step(upOff, roundStep)
                                bool foundU = false
                                if array.size(highBins) > 0
                                    for i = 0 to array.size(highBins) - 1
                                        if math.abs(array.get(highBins, i) - keyU) <= syminfo.mintick * 0.5
