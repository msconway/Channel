        int enabledCount = (showAsia ? 1 : 0) + (showLondon ? 1 : 0) + (showNewYork ? 1 : 0) + (showNyLunch ? 1 : 0) + (showNyPm ? 1 : 0)
        int maxSessions = enabledCount
        if array.size(sessionXs) > 0 and maxSessions > 0
            int startIdx = math.max(array.size(sessionXs) - maxSessions, 0)
            int labelYOff = 0
            for i = startIdx to array.size(sessionXs) - 1
                int sx = array.get(sessionXs, i)
